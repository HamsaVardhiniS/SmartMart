generator client {
 provider = "prisma-client-js"
}

datasource db {
 provider = "postgresql"
 url      = env("DATABASE_URL")
}

model SalesSummaryDaily {
 summary_date DateTime @id
 total_revenue Decimal @default(0)
 total_tax Decimal @default(0)
 total_transactions Int @default(0)

 @@map("sales_summary_daily")
}

model ProductSalesSummary {
 product_id Int
 branch_id Int
 total_quantity Int @default(0)
 total_revenue Decimal @default(0)

 @@id([product_id,branch_id])
 @@map("product_sales_summary")
}

model InventorySummary {
 product_id Int
 branch_id Int
 current_stock Int @default(0)
 stock_value Decimal @default(0)

 @@id([product_id,branch_id])
 @@map("inventory_summary")
}

model PayrollSummary {
 payroll_month Int
 payroll_year Int
 total_payroll Decimal @default(0)

 @@id([payroll_month,payroll_year])
 @@map("payroll_summary")
}

model SupplierSummary {
 supplier_id Int
 branch_id Int
 total_purchase_value Decimal @default(0)

 @@id([supplier_id,branch_id])
 @@map("supplier_summary")
}

model event_log {
  event_id     String   @id
  processed_at DateTime @default(now())
}

model failed_events {
  id         Int      @id @default(autoincrement())
  event_id   String
  payload    Json
  error      String
  created_at DateTime @default(now())
}