generator client {
  provider = "prisma-client-js"
 binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



enum employee_status_enum {
  Active
  Inactive
}

enum leave_status_enum {
  Pending
  Approved
  Rejected
}



model departments {
  department_id   Int     @id @default(autoincrement())
  department_name String  @unique
  manager_id      Int?

  // Relations
  manager   employees? @relation("DepartmentManager", fields: [manager_id], references: [employee_id])
  employees employees[]

  @@map("departments")
}

model employees {
  employee_id         Int      @id @default(autoincrement())
  branch_id           Int
  first_name          String?
  last_name           String?
  department_id       Int?
  phone               String?  @unique
  email               String?  @unique
  address             String?
  dob                 DateTime?
  gender              String?
  emergency_contact   String?
  hire_date           DateTime?
  status              employee_status_enum @default(Active)
  password_hash       String
  bank_account_number String   @unique
  bank_name           String
  ifsc_code           String
  account_holder_name String
  salary              Decimal  @db.Decimal(12, 2)
  allowed_leaves      Int?     @default(12)

  // Relations
  department departments? @relation(fields: [department_id], references: [department_id])
  managedDepartments departments[] @relation("DepartmentManager")
  password_resets password_resets[]

  attendance      attendance[]
  leave_requests  leave_requests[]
  payroll         payroll[]
  leave_balance   leave_balance?

  @@map("employees")
}

model attendance {
  attendance_id   BigInt   @id @default(autoincrement())
  employee_id     Int
  attendance_date DateTime
  check_in_time   DateTime?
  check_out_time  DateTime?
  total_hours     Decimal? @db.Decimal(5, 2)
  overtime_hours  Decimal? @default(0) @db.Decimal(5, 2)

  // Relation
  employee employees @relation(fields: [employee_id], references: [employee_id], onDelete: Cascade)

  @@unique([employee_id, attendance_date])
  @@map("attendance")
}

model leave_balance {
  employee_id     Int     @id
  total_allowed   Int
  used_leaves     Int?    @default(0)
  remaining_leaves Int?   @ignore

  employee employees @relation(fields: [employee_id], references: [employee_id], onDelete: Cascade)

  @@map("leave_balance")
}

model leave_requests {
  leave_id    Int      @id @default(autoincrement())
  employee_id Int
  leave_type  String?
  start_date  DateTime
  end_date    DateTime
  status      leave_status_enum @default(Pending)

  employee employees @relation(fields: [employee_id], references: [employee_id], onDelete: Cascade)

  @@map("leave_requests")
}

model payroll {
  payroll_id      BigInt  @id @default(autoincrement())
  employee_id     Int
  payroll_month   Int
  payroll_year    Int
  base_salary     Decimal @db.Decimal(12, 2)
  leave_deduction Decimal? @db.Decimal(12, 2)
  bonus           Decimal? @db.Decimal(12, 2)
  net_salary      Decimal? @db.Decimal(12, 2) @ignore

  employee employees @relation(fields: [employee_id], references: [employee_id], onDelete: Cascade)

  @@unique([employee_id, payroll_month, payroll_year])
  @@map("payroll")
}

model password_resets {
  reset_id    Int      @id @default(autoincrement())
  employee_id Int
  reset_token String
  expiry_time DateTime
  is_used     Boolean  @default(false)

  employee employees @relation(fields: [employee_id], references: [employee_id], onDelete: Cascade)

  @@map("password_resets")
}

model event_log {
  event_id     String   @id
  processed_at DateTime @default(now())
}

model failed_events {
  id         Int      @id @default(autoincrement())
  event_id   String
  payload    Json
  error      String
  created_at DateTime @default(now())
}
