{
    "compilerOptions": {
        /* Language */
        "target": "ES2020",
        "lib": [
            "ES2020"
        ],
        "module": "CommonJS",
        /* Output */
        "rootDir": "./src",
        "outDir": "./dist",
        /* Strictness */
        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        /* Interop */
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        /* Module Resolution */
        "moduleResolution": "node",
        "resolveJsonModule": true,
        /* Performance */
        "skipLibCheck": true,
        /* Debugging */
        "sourceMap": true,
        /* Types */
        "types": [
            "node"
        ]
    },
    "include": [
        "src"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}